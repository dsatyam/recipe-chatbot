# -----------------------------------------------------------------------------
# Environment template — copy to ".env" and fill in. Never commit .env to Git.
# Loaded by pydantic-settings in app/config.py (class Settings).
# Full variable reference: README.md and PROJECT_WALKTHROUGH.md.
# -----------------------------------------------------------------------------

# Required for OpenAI; some OpenAI-compatible local servers accept any non-empty string.
OPENAI_API_KEY=sk-...

# Optional: leave unset for api.openai.com. Set for Ollama/vLLM/LiteLLM/etc.
# Passed to AsyncOpenAI(base_url=...) in app/chat.py.
# OPENAI_BASE_URL=http://localhost:11434/v1

# Model id (OpenAI model name or your server's model id). Read in app/chat.py.
OPENAI_MODEL=gpt-4o-mini

# Optional path overrides (relative to project root when you run uvicorn from there).
# Resolved in app/config.py via resolved_behavior_file() / resolved_traces_file().
# BEHAVIOR_FILE=config/agent_behavior.md
# TRACES_FILE=data/traces.json
